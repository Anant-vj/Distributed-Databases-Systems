  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.15.0",
  "devDependencies": {
    "@types/node": "^22.15.0",
    "fast-check": "^3.23.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  }
}
