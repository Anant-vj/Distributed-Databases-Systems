{
  "name": "anvil-local-first-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:all": "python tests/run_all.py",
    "test:watch": "vitest",
    "demo": "tsx demo/reference-trace.ts",
    "demo:annex-a": "tsx demo/annex-a-reference.ts",
    "bench:bridge": "tsx src/cli/bench-bridge.ts",
